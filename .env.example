FILE_STORAGE_S3_SERVICE_URL=
FILE_STORAGE_S3_ACCESS_KEY_ID=
FILE_STORAGE_S3_SECRET_ACCESS_KEY=
FILE_STORAGE_S3_KEY_PREFIX=startupconnect
FILE_STORAGE_S3_FORCE_PATH_STYLE=false
FILE_STORAGE_S3_USE_SERVER_SIDE_ENCRYPTION=true
OBSERVABILITY_ENABLE_REQUEST_LOGGING=true
OBSERVABILITY_USE_JSON_CONSOLE=false
OBSERVABILITY_CORRELATION_HEADER_NAME=X-Correlation-Id
OBSERVABILITY_SLOW_REQUEST_THRESHOLD_MS=1000
RATE_LIMITING_ENABLED=true
