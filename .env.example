CORS_ALLOWED_ORIGIN_3=http://127.0.0.1:5173
SECURITY_USE_FORWARDED_HEADERS=false
SECURITY_REQUIRE_HTTPS_REDIRECTION=false
REFRESH_TOKEN_COOKIE_ENABLED=false
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=Lax
PAYMENTS_PROVIDER=Mock
PAYMENTS_WEBHOOK_SECRET=DEV_ONLY_PaymentWebhookSecret_ReplaceInProduction
PAYMENTS_CHECKOUT_BASE_URL=http://localhost:3000/billing/checkout
